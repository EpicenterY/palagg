# Connection mode: "lan" (direct IP) or "cloud" (Bambu Cloud)
CONNECTION_MODE=cloud

# Printer Configuration
PRINTER_ID=bambu_x1c_01
PRINTER_NAME=Bambu X1C
PRINTER_MODEL=X1C
PRINTER_IP=192.168.1.100
PRINTER_ACCESS_CODE=your_access_code_here
PRINTER_SERIAL=your_serial_number_here
PRINTER_DEV_ID=

# Bambu Cloud (required when CONNECTION_MODE=cloud)
# Option 1: provide access token directly (from Bambu Studio log)
BAMBU_ACCESS_TOKEN=
# Option 2: email/password login (no 2FA accounts only)
BAMBU_EMAIL=
BAMBU_PASSWORD=
# Cloud MQTT broker (default: us.mqtt.bambulab.com)
BAMBU_MQTT_BROKER=us.mqtt.bambulab.com
BAMBU_API_BASE=https://api.bambulab.com

# Server
PORT=3000
HOST=0.0.0.0

# Data paths
DATA_DIR=C:/palagg-data
SLICER_PATH=C:/Program Files/Bambu Studio/bambu-studio.exe
# Slicer presets (must match names in BambuStudio/system/BBL/)
SLICER_MACHINE_PRESET=Bambu Lab X1 Carbon 0.4 nozzle
SLICER_PROCESS_PRESET=0.20mm Standard @BBL X1C
SLICER_FILAMENT_PRESET=Bambu PLA Basic @BBL X1C

# Frontend origin (for CORS)
CORS_ORIGIN=http://localhost:5173,https://palagg.vercel.app
